# DATABASE_URL tells the API how to connect to PostgreSQL.
# Here it points to the local Postgres container from docker-compose.
# The future API database client will read this value.
DATABASE_URL=postgresql://postgres:postgres@db:5432/agentapp
REDIS_URL=redis://redis:6379
API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
APP_ENV=development
# OPENAI_API_KEY enables real AI generation for the Growth agent.
# Add your own key in a real .env file. Do not put a real secret in .env.example.
OPENAI_API_KEY=your_openai_api_key_here

# OPENAI_MODEL is optional. If omitted, the Growth agent uses gpt-5-mini.
OPENAI_MODEL=gpt-5-mini
