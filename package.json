{
  "name": "agent-app",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-agent application project",
  "scripts": {
    "build": "npm run build:api && npm run build:web",
    "build:api": "npm run build --prefix apps/api",
    "build:web": "npm run build --prefix apps/web",
    "db:check": "npm run check-db --prefix apps/api",
    "db:apply-schema": "npm run apply-schema --prefix apps/api",
    "db:backup": "mkdir -p backups && pg_dump \"$DATABASE_URL\" -Fc -f \"${BACKUP_FILE:-backups/agent-app-$(date +%Y%m%d-%H%M%S).dump}\"",
    "db:restore": "test -n \"$RESTORE_FILE\" && pg_restore --clean --if-exists --no-owner --no-privileges -d \"$DATABASE_URL\" \"$RESTORE_FILE\"",
    "api": "npm run dev --prefix apps/api",
    "start:api": "npm run start --prefix apps/api",
    "web": "npm run dev --prefix apps/web",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run api\" \"npm run web\"",
    "health": "node scripts/health-check.mjs",
    "smoke:ownership": "node scripts/ownership-smoke.mjs",
    "smoke:session-ownership": "node scripts/session-ownership-smoke.mjs",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:restart": "pm2 restart agent-api",
    "pm2:status": "pm2 status agent-api",
    "pm2:monit": "pm2 monit",
    "pm2:logs": "pm2 logs agent-api"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^4.104.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "concurrently": "^9.2.1"
  }
}
