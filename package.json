{
  "name": "agent-app",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-agent application project",
  "scripts": {
    "api": "npm run dev --prefix apps/api",
    "web": "npm run dev --prefix apps/web",
    "dev": "concurrently -k -n api,web -c blue,green \"npm run api\" \"npm run web\""
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "openai": "^4.104.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "concurrently": "^9.2.1"
  }
}
